{
  "cleanUrls": true,
  "trailingSlash": false,
  "outputDirectory": "out",
  "redirects": [
    {
      "source": "/",
      "missing": [
        { "type": "host", "value": "amvo.store" },
        { "type": "host", "value": "www.amvo.store" }
      ],
      "destination": "/en/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "amvo.store" }],
      "destination": "/amvo-store/$1"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.amvo.store" }],
      "destination": "/amvo-store/$1"
    }
  ]
}
